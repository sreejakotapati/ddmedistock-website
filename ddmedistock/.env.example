# ─────────────────────────────────────────────────────────────────────────
# DDMediStock environment configuration
# Copy to `.env` (local), `.env.development`, `.env.staging`, `.env.production`
# and fill in per environment. NEVER commit real secrets — only this template.
# ─────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16 + pgvector + pg_trgm) ───────────────────────────
# Local dev (matches docker-compose / local cluster):
DATABASE_URL="postgresql://ddmedistock:ddmedistock@127.0.0.1:5433/ddmedistock?schema=public"
# Production example (managed Postgres, TLS required, connection pool):
#   DATABASE_URL="postgresql://USER:PASS@db.internal:5432/ddmedistock?schema=public&sslmode=require&connection_limit=20"
# When using a pooler (PgBouncer / Prisma Accelerate) also set a direct URL
# for migrations:
# DIRECT_DATABASE_URL="postgresql://USER:PASS@db.internal:5432/ddmedistock?schema=public&sslmode=require"

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"

# ── AI (optional) ───────────────────────────────────────────────────────────
# When OPENAI_API_KEY is set the AI engine uses OpenAI; otherwise a
# deterministic heuristic/offline fallback runs so the app stays functional.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ── Queues (Redis + BullMQ) ─────────────────────────────────────────────────
# When set, RFQ/OCR/AI/quotation/notification/email jobs run via BullMQ workers
# (`npm run worker`). When unset, jobs run inline so the app works without Redis.
# REDIS_URL="redis://127.0.0.1:6379"

# ── Email (Resend, optional) ────────────────────────────────────────────────
# RESEND_API_KEY=""
# EMAIL_FROM="DD MediStock <no-reply@ddmedistock.example>"

# ── Public website enquiry form (WhatsApp/Call site) ────────────────────────
# Public site base URL (used for SEO sitemap, robots, canonical, OG, JSON-LD).
NEXT_PUBLIC_SITE_URL="https://www.ddmedistock.com"
# Inbox that receives new-enquiry email notifications.
NOTIFY_EMAIL="md@sarnga.co.in"
# Google Apps Script Web App URL — appends the enquiry to a Google Sheet AND
# emails NOTIFY_EMAIL. See docs/INTEGRATIONS.md for the script + setup steps.
# GOOGLE_SHEETS_WEBHOOK_URL="https://script.google.com/macros/s/XXXXX/exec"
# Shared secret checked by the Apps Script to reject forged posts (recommended).
# GOOGLE_SHEETS_WEBHOOK_TOKEN="a-long-random-string"
# If GOOGLE_SHEETS_WEBHOOK_URL is unset, enquiry emails fall back to Resend
# (set RESEND_API_KEY above). With neither set, submissions are logged only.

# ── OCR (optional) ──────────────────────────────────────────────────────────
# Local OCR uses the tesseract + poppler binaries (bundled in the Docker image).
# For higher accuracy / handwriting, point at an external PaddleOCR-style
# microservice that accepts the raw file bytes and returns { "text": "..." }.
# OCR_SERVICE_URL="http://paddleocr:8080/ocr"

# ── Observability ───────────────────────────────────────────────────────────
# Pino log level: trace|debug|info|warn|error (default info in prod, debug dev).
LOG_LEVEL="info"
# Sentry error tracking (optional). Set SENTRY_DSN and `npm i @sentry/node`
# to forward exceptions; otherwise captureException just logs.
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# ── Backups (scripts/db-backup.sh) ──────────────────────────────────────────
# Local directory for pg_dump archives; optional S3 bucket for off-site copies.
BACKUP_DIR="./backups"
# BACKUP_S3_BUCKET="s3://ddmedistock-backups"
# BACKUP_RETENTION_DAYS="14"
